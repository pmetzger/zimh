*#

# Ignore local editor state.
.vscode/
.vs/
**/*.code-workspace
**/.vscode/

# Ignore local build and install trees.
/build/
SIMH-install

# Temporary plain-text extractions and staging used when proofreading
# legacy Word documents against their Markdown conversions.
tmp/word-text/
tmp/word-text-stage.*/

# Temporary working tree containing existing Markdown conversions and
# exported assets while the Word-document replacement effort is ongoing.
simh-docs/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
